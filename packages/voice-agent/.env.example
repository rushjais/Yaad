# Track A — voice-agent environment variables
# Copy to .env and fill in values from sponsor table / team

# LiveKit
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=yaad-demo

# Deepgram STT
DEEPGRAM_API_KEY=

# MiniMax TTS  [CONFIRM voice IDs at sponsor table]
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_VOICE_EN=male-qn-jingying   # [CONFIRM]
MINIMAX_VOICE_HI=female-shaonv      # [CONFIRM]
MINIMAX_MODEL=speech-01-hd          # [CONFIRM]

# TrueFoundry LLM gateway  [CONFIRM base_url + model at sponsor table]
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=https://llm.truefoundry.com/api/inference/openai
TRUEFOUNDRY_MODEL=openai-main/gpt-4o-mini

# Memory engine (Track B)
MEMORY_ENGINE_URL=http://localhost:8000
