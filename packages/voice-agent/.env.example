# Track A — voice-agent environment variables
# cp .env.example .env and fill in the blanks

# Groq Whisper STT (replaces Deepgram)
GROQ_API_KEY=

# MiniMax TTS — international endpoint (api.minimax.io, NOT .chat)
MINIMAX_API_KEY=
MINIMAX_VOICE_EN=English_Graceful_Lady
MINIMAX_MODEL=speech-02-hd

# LiveKit (only needed for LiveKit mode; --local skips this)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=yaad-demo

# TrueFoundry LLM gateway (or set OPENAI_API_KEY / ANTHROPIC_API_KEY as fallback)
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=https://gateway.truefoundry.ai
TRUEFOUNDRY_MODEL=openai/gpt-4o-mini

# Memory engine (Track B)
MEMORY_ENGINE_URL=http://localhost:8000
