  "components": {
    "schemas": {
      "EntityType": {
        "type": "string",
        "enum": [
          "person",
          "place",
          "event",
          "medication",
          "med_log",
          "story",
          "episode"
        ],
        "title": "EntityType"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "moss_ok": {
            "type": "boolean",
            "title": "Moss Ok"
          },
          "db_ok": {
            "type": "boolean",
            "title": "Db Ok"
          },
          "latency_ms": {
            "type": "number",
            "title": "Latency Ms"
          }
        },
        "type": "object",
        "required": [
          "moss_ok",
          "db_ok",
          "latency_ms"
        ],
        "title": "HealthResponse"
      },
      "LocationAction": {
        "type": "string",
        "enum": [
          "none",
          "reassure",
          "alert"
        ],
        "title": "LocationAction"
      },
      "LocationPingRequest": {
        "properties": {
          "lat": {
            "type": "number",
            "title": "Lat"
          },
          "lng": {
            "type": "number",
            "title": "Lng"
          }
        },
        "type": "object",
        "required": [
          "lat",
          "lng"
        ],
        "title": "LocationPingRequest"
      },
      "LocationPingResponse": {
        "properties": {
          "inside_zone": {
            "type": "boolean",
            "title": "Inside Zone"
          },
          "nearest_place": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Nearest Place"
          },
          "action": {
            "$ref": "#/components/schemas/LocationAction"
          },
          "reassurance_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reassurance Text"
          },
          "contacts": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Contacts"
          }
        },
        "type": "object",
        "required": [
          "inside_zone",
          "nearest_place",
          "action"
        ],
        "title": "LocationPingResponse"
      },
      "MemoryCaptureRequest": {
        "properties": {
          "transcript": {
            "type": "string",
            "title": "Transcript"
          }
        },
        "type": "object",
        "required": [
          "transcript"
        ],
        "title": "MemoryCaptureRequest"
      },
      "MemoryCaptureResponse": {
        "properties": {
          "created_refs": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Created Refs"
          }
        },
        "type": "object",
        "required": [
          "created_refs"
        ],
        "title": "MemoryCaptureResponse"
      },
      "MemoryQueryRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "lang": {
            "type": "string",
            "title": "Lang",
            "default": "en"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "MemoryQueryRequest"
      },
      "MemoryQueryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/RetrievedItem"
            },
            "type": "array",
            "title": "Items"
          },
          "grounded": {
            "type": "boolean",
            "title": "Grounded"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "answer_draft": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer Draft"
          }
        },
        "type": "object",
        "required": [
          "items",
          "grounded",
          "confidence"
        ],
        "title": "MemoryQueryResponse"
      },
      "MemoryWriteRequest": {
        "properties": {
          "type": {
            "$ref": "#/components/schemas/MemoryWriteType"
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload"
          }
        },
        "type": "object",
        "required": [
          "type",
          "payload"
        ],
        "title": "MemoryWriteRequest"
      },
      "MemoryWriteResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          }
        },
        "type": "object",
        "required": [
          "id"
        ],
        "title": "MemoryWriteResponse"
      },
      "MemoryWriteType": {
        "type": "string",
        "enum": [
          "person",
          "place",
          "event",
          "medication",
          "med_log",
          "story",
          "episode"
        ],
        "title": "MemoryWriteType"
      },
      "Provenance": {
        "properties": {
          "source": {
            "type": "string",
            "title": "Source"
          },
          "added_by": {
            "type": "string",
            "title": "Added By"
          },
          "added_ts": {
            "type": "string",
            "format": "date-time",
            "title": "Added Ts"
          }
        },
        "type": "object",
        "required": [
          "source",
          "added_by",
          "added_ts"
        ],
        "title": "Provenance"
      },
      "ReminderItem": {
        "properties": {
          "kind": {
            "type": "string",
            "title": "Kind"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "ref": {
            "type": "string",
            "title": "Ref"
          }
        },
        "type": "object",
        "required": [
          "kind",
          "text",
          "ref"
        ],
        "title": "ReminderItem"
      },
      "RemindersResponse": {
        "properties": {
          "due": {
            "items": {
              "$ref": "#/components/schemas/ReminderItem"
            },
            "type": "array",
            "title": "Due"
          }
        },
        "type": "object",
        "required": [
          "due"
        ],
        "title": "RemindersResponse"
      },
      "RetrievedItem": {
        "properties": {
          "ref": {
            "type": "string",
            "title": "Ref"
          },
          "type": {
            "$ref": "#/components/schemas/EntityType"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "provenance": {
            "$ref": "#/components/schemas/Provenance"
          }
        },
        "type": "object",
        "required": [
          "ref",
          "type",
          "text",
          "score",
          "provenance"
        ],
        "title": "RetrievedItem"
      },
      "TimelineBlock": {
        "properties": {
          "ts": {
            "type": "string",
            "format": "date-time",
            "title": "Ts"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "summary": {
            "type": "string",
            "title": "Summary"
          },
          "entity_refs": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Entity Refs"
          }
        },
        "type": "object",
        "required": [
          "ts",
          "type",
          "title",
          "summary"
        ],
        "title": "TimelineBlock"
      },
      "TimelineResponse": {
        "properties": {
          "blocks": {
            "items": {
              "$ref": "#/components/schemas/TimelineBlock"
            },
            "type": "array",
            "title": "Blocks"
          }
        },
        "type": "object",
        "required": [
          "blocks"
        ],
        "title": "TimelineResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VisionRecognizeRequest": {
        "properties": {
          "image_b64": {
            "type": "string",
            "title": "Image B64"
          }
        },
        "type": "object",
        "required": [
          "image_b64"
        ],
        "title": "VisionRecognizeRequest"
      },
      "VisionRecognizeResponse": {
        "properties": {
          "match": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RetrievedItem"
              },
              {
                "type": "null"
              }
            ]
          },
          "answer_draft": {
            "type": "string",
            "title": "Answer Draft"
          }
        },
        "type": "object",
        "required": [
          "match",
          "answer_draft"
        ],
        "title": "VisionRecognizeResponse"
      }
    }
  }
}