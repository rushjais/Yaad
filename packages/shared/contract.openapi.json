    "/memory/timeline": {
      "get": {
        "summary": "Memory Timeline",
        "operationId": "memory_timeline_memory_timeline_get",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
