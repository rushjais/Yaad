# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Moss — on-device SDK (pip install moss)
# Get PROJECT_ID and PROJECT_KEY from portal.getmoss.dev
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX=yaad_amma

# MiniMax TTS
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Groq (LLM gateway)
GROQ_API_KEY=

# Deepgram STT
DEEPGRAM_API_KEY=

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# TrueFoundry LLM gateway (optional if using Groq)
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=
TRUEFOUNDRY_MODEL=

# OpenAI (vision fallback — optional)
OPENAI_API_KEY=

# Wander alerts — email-to-SMS via carrier gateways. We removed Twilio
# because trial toll-free numbers require 3-7d verification; this path is
# instant, free, and looks like a normal SMS on the recipient's phone.
EMAIL_FROM=
EMAIL_APP_PASSWORD=               # 16-char Google app password; revocable any time
# Recipient address: <number>@<carrier-gateway>. Common gateways:
#   Google Fi:  6505551234@msg.fi.google.com
#   AT&T:       6505551234@txt.att.net
#   T-Mobile:   6505551234@tmomail.net
YAAD_DEMO_RECIPIENT_EMAIL=

# Unsiloed (document ingestion)
UNSILOED_API_KEY=
UNSILOED_BASE_URL=https://platformbackend.unsiloed.ai

# Retrieval scoring weights (defaults are good; tune after seeding)
CONFIDENCE_THRESHOLD=0.45
ALPHA=0.5
BETA=0.25
GAMMA=0.15
DELTA=0.10
RECENCY_LAMBDA=0.01
